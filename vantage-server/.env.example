# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/vantage_db?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/vantage_db?retryWrites=true&w=majority

# JWT Secret Key
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_random_string_here_min_32_chars

# Node Environment
NODE_ENV=production

# Server Port
PORT=3001

# Client URL (for CORS)
# Example: https://vantage.vercel.app
CLIENT_URL=https://your-vercel-app.vercel.app
